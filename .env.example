# AI Key

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM
#LLM_JUDGE_PROVIDER=anthropic
#LLM_JUDGE_MODEL=claude-haiku-4-5-20251001
LLM_JUDGE_PROVIDER=openai
LLM_JUDGE_MODEL=gpt-4o-mini

MAX_ITERATIONS=3
MIN_QUALITY_SCORE=7.5
AVG_QUALITY_SCORE=8.0

#ITSM_LLM_MODEL=gpt-4.1-mini
ITSM_LLM_MODEL=gpt-5-mini
ITSM_LLM_TEMPERATURE=0.2
ITSM_LLM_MAX_RETRIES=1
ITSM_LLM_TIMEOUT_SECONDS=45

# langsmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=itsm-eval-set
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
